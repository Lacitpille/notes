---
import { url } from '../lib/url';

interface Props {
  title: string;
  pubDate: Date;
  slug: string;
  tags: string[];
  description?: string;
}

const { title, pubDate, slug, tags, description } = Astro.props;
const dateStr = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<article class="py-6 border-b border-gray-100 last:border-0">
  <time class="text-sm text-gray-500">{dateStr}</time>
  <h2 class="mt-1 text-xl font-semibold">
    <a href={url('/posts/' + slug + '/')} class="text-gray-900 hover:text-gray-600 no-underline">
      {title}
    </a>
  </h2>
  {description && <p class="mt-1 text-gray-600 text-sm">{description}</p>}
  {tags.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-2">
      {tags.map(tag => (
        <a href={url('/tags/' + tag + '/')} class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded hover:bg-gray-200 no-underline">
          {tag}
        </a>
      ))}
    </div>
  )}
</article>
