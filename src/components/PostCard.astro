---
import { url } from '../lib/url';

interface Props {
  title: string;
  pubDate: Date;
  slug: string;
  tags: string[];
  description?: string;
}

const { title, pubDate, slug, tags, description } = Astro.props;
const dateStr = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<article class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 p-6">
  <time class="text-xs font-medium text-indigo-400 dark:text-indigo-500 uppercase tracking-wide">{dateStr}</time>
  <h2 class="mt-2 text-xl font-semibold leading-snug">
    <a href={url('/posts/' + slug + '/')} class="text-gray-900 dark:text-gray-100 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors no-underline">
      {title}
    </a>
  </h2>
  {description && <p class="mt-2 text-gray-500 dark:text-gray-400 text-sm leading-relaxed">{description}</p>}
  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map(tag => (
        <a href={url('/tags/' + tag + '/')} class="text-xs bg-indigo-50 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400 px-2.5 py-0.5 rounded-full font-medium hover:bg-indigo-100 dark:hover:bg-indigo-900 transition-colors no-underline">
          {tag}
        </a>
      ))}
    </div>
  )}
</article>
