---
import { url } from '../lib/url';
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-sm border-b border-gray-200 shadow-sm">
  <div class="max-w-2xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href={url('/')} class="text-lg font-bold text-indigo-600 hover:text-indigo-700 transition-colors no-underline tracking-tight">
      Math Notes
    </a>
    <nav class="flex gap-6 text-sm font-medium">
      <a href={url('/posts/')} class="text-gray-500 hover:text-indigo-600 transition-colors no-underline relative group">
        Posts
        <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-indigo-600 transition-all group-hover:w-full"></span>
      </a>
      <a href={url('/tags/')} class="text-gray-500 hover:text-indigo-600 transition-colors no-underline relative group">
        Tags
        <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-indigo-600 transition-all group-hover:w-full"></span>
      </a>
    </nav>
  </div>
</header>
